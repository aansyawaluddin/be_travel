generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Staff {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  password  String
  nama      String
  bookings  Booking[] 
  createdAt DateTime  @default(now())
}

model Package {
  id        String    @id
  nama      String
  harga     Float
  kapasitas Int
  bookings  Booking[] 
}

model Booking {
  id                Int      @id @default(autoincrement())
  namaPemesan       String
  kontak            String
  tanggalBerangkat  DateTime
  jumlahPeserta     Int
  hargaPerOrang     Float
  status            String   @default("Menunggu")
  catatan           String?
  
  packageId         String
  package           Package  @relation(fields: [packageId], references: [id])
  
  staffId           Int
  staff             Staff    @relation(fields: [staffId], references: [id])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}